spring:
  application:
    name: RentCar

  datasource:
    url: jdbc:postgresql://[NEON_HOST]/neondb?sslmode=require
    driver-class-name: org.postgresql.Driver
    username: [NEON_USERNAME]
    password: [NEON_PASSWORD]

  jpa:
    database-platform: org.hibernate.dialect.PostgreSQLDialect
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

server:
  port: 8080

logging:
  level:
    br.com.unipaulistana.rentacar: INFO
    org.hibernate.SQL: INFO
